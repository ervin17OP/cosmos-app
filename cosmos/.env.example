# Variables d'environnement COSMOS
# Copiez ce fichier en .env.local et remplissez vos valeurs

# Supabase — Récupérables dans Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat (optionnel — pour les abonnements freemium)
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxx
