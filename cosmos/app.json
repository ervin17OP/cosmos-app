{
  "expo": {
    "name": "COSMOS",
    "slug": "cosmos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0d18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cosmos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0d18"
      },
      "package": "com.cosmos.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "cosmos",
    "experiments": {
      "typedRoutes": true
    }
  }
}
